# Lucid Voice — backend environment configuration (example).
# Copy to ".env" and adjust. Local-first: every default below works fully
# on-device (airplane-mode safe). Cloud providers are OPT-IN only and require
# their respective API keys. NEVER commit real secrets.

# ---------------------------------------------------------------------------
# Provider selection. "local" keeps everything on-device.
# ---------------------------------------------------------------------------
LLM_PROVIDER=local              # local (LM Studio) | claude (cloud, opt-in)
EMBEDDING_PROVIDER=local        # local (sentence-transformers)
STT_PROVIDER=local              # local (faster-whisper) | deepgram (cloud, opt-in)
TTS_PROVIDER=local              # local (Coqui XTTS-v2) | elevenlabs (cloud, opt-in)

# ---------------------------------------------------------------------------
# Modes
# ---------------------------------------------------------------------------
DEMO_MODE=false                 # true -> deterministic playback from demo_fixtures.json

# ---------------------------------------------------------------------------
# Local LLM (LM Studio, OpenAI-compatible server)
# ---------------------------------------------------------------------------
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model     # model id as exposed by LM Studio

# ---------------------------------------------------------------------------
# Cloud LLM (Anthropic / Claude) — opt-in, used only when LLM_PROVIDER=claude
# ---------------------------------------------------------------------------
CLAUDE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Embeddings (local sentence-transformers, 384-dim)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---------------------------------------------------------------------------
# STT (local faster-whisper). Browser webm/opus is decoded to PCM via FFmpeg.
# small.en transcribes a short utterance in <1s on Apple Silicon CPU.
# ---------------------------------------------------------------------------
WHISPER_MODEL=small.en          # tiny(.en) | base(.en) | small(.en) | medium(.en) | large-v3
WHISPER_COMPUTE_TYPE=int8       # int8 (CPU) | float16 (GPU)
WHISPER_BEAM_SIZE=5
WHISPER_LANGUAGE=en
DEEPGRAM_API_KEY=               # only used when STT_PROVIDER=deepgram
DEEPGRAM_MODEL=nova-2

# ---------------------------------------------------------------------------
# TTS / voice clone
# Local default is Coqui XTTS-v2 (PyPI "coqui-tts", the idiap fork). It requires
# FFmpeg installed on the system for audio IO (macOS: `brew install ffmpeg`).
# XTTS runs on CPU on Apple Silicon. First use downloads ~1.8GB of weights.
# ---------------------------------------------------------------------------
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=en
TTS_TIMEOUT=60
ELEVENLABS_API_KEY=             # only used when TTS_PROVIDER=elevenlabs
ELEVENLABS_VOICE_ID=            # cloned/preset voice id for ElevenLabs
ELEVENLABS_MODEL=eleven_multilingual_v2

# ---------------------------------------------------------------------------
# Storage paths (env names match app/config.py Settings fields)
# ---------------------------------------------------------------------------
KUZU_DB_PATH=./data/kuzu_db     # embedded graph database directory
VOICES_DIR=./data/voices        # enrolled speaker reference audio
CACHE_DIR=./data/cache          # cached synthesized speech
